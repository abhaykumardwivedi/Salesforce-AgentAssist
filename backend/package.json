{
  "name": "salesforce-agentassist-backend",
  "version": "0.1.0",
  "description": "Node and Express REST API for Salesforce AgentAssist",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --no-warnings --watch src/server.js",
    "start": "node --no-warnings src/server.js",
    "db:setup": "node scripts/setup-postgres.js",
    "db:migrate": "node --no-warnings scripts/migrate.js",
    "db:reset-local": "node --no-warnings scripts/reset-local-db.js",
    "rotate:encryption-key": "node --no-warnings scripts/rotate-encryption-key.js",
    "test": "node --no-warnings --import ./setup-env.js --test --test-concurrency=1"
  },
  "dependencies": {
    "@sentry/node": "^8.47.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "zod": "^4.4.3"
  }
}
