# Backend
NODE_ENV=development
PORT=8080
FRONTEND_ORIGIN=http://localhost:5173

# SQLite database file. Leave blank to use backend/data/agentassist.sqlite
DB_PATH=

# Supabase/PostgreSQL deployment. When set, backend uses Postgres instead of SQLite.
DATABASE_URL=
DATABASE_SSL=true

# Authentication. Generate strong random values for production.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Encryption key for per-tenant integration secrets (32-byte hex, or any passphrase).
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# Seed admin for the demo workspace (created on first boot if no users exist).
SEED_ADMIN_EMAIL=admin@demo.test
SEED_ADMIN_PASSWORD=ChangeMe123!

# Rate limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Fallback AI mode for the demo workspace when no per-tenant OpenAI key is saved.
# In production, each tenant saves their own key from Settings (stored encrypted).
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=20000

# Salesforce connected app (OAuth web-server flow). One app for the platform;
# each tenant authorizes their own org from Settings. Tokens are stored encrypted per tenant.
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_API_VERSION=v60.0
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:8080/api/v1/salesforce/oauth/callback

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api/v1
