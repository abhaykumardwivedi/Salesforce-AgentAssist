# Backend
NODE_ENV=development
PORT=8080
FRONTEND_ORIGIN=http://localhost:5173

# SQLite database file. Leave blank to use backend/data/agentassist.sqlite
DB_PATH=

# Supabase/PostgreSQL deployment. When set, backend uses Postgres instead of SQLite.
DATABASE_URL=
DATABASE_SSL=true

# Mock mode runs locally without Salesforce credentials.
SALESFORCE_ENABLED=true
SALESFORCE_MODE=MOCK
SALESFORCE_API_VERSION=v60.0

# Real Salesforce mode, demo only. Username-password OAuth is not recommended long-term.
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api/v1
